# Example PostgreSQL DATABASE_URL
# Replace user, password, host, port, and dbname accordingly
DATABASE_URL="postgresql://postgres:password@localhost:5432/getcode_db"

# If you prefer SQLite for local development, you can instead use:
# DATABASE_URL="file:./dev.db"

